{
  "name": "my-agent",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "eve build",
    "build:ui": "tsgo -p web/tsconfig.json",
    "dev": "eve dev",
